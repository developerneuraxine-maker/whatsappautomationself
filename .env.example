# ---------------------------------------------------------------------------
# WhatsApp Cloud API (Meta) — server-side only. Never expose these to the
# browser (do NOT prefix with NEXT_PUBLIC_). Copy this file to `.env.local`
# and fill in the values from your Meta App + WhatsApp Manager.
# ---------------------------------------------------------------------------

# Permanent system-user access token (Business Settings → System Users).
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID for your business number (WhatsApp → API Setup).
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Business Account (WABA) ID. Optional, used for management calls.
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Graph API version. Optional — defaults to v21.0 if unset.
WHATSAPP_API_VERSION=v21.0

# A token you invent, entered in the Meta webhook config to verify ownership.
WHATSAPP_VERIFY_TOKEN=

# App secret (Meta App → Settings → Basic). Optional but recommended: when set,
# incoming webhook payloads are validated against the X-Hub-Signature-256 header.
WHATSAPP_APP_SECRET=

# Optional auto-reply sent to any incoming text message. Leave blank to disable.
WHATSAPP_AUTO_REPLY_MESSAGE=

# ---------------------------------------------------------------------------
# Persistence (optional)
# ---------------------------------------------------------------------------
# Durable storage for the app data snapshot. Pick ONE:
#   - Set DATABASE_URL to a Postgres connection string (Supabase/Neon/Vercel
#     Postgres) for production. Required on serverless (Vercel), where the
#     filesystem is ephemeral.
#   - Leave unset for local dev: state is written to ./.data/state.json.
# With neither, the app runs purely in-memory (resets on restart).
DATABASE_URL=

# Set to "disable" only if your Postgres does not use TLS (rare).
DATABASE_SSL=